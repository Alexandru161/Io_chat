{
  auto_https prefer_wildcard
}

(app) {
  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
  }

  @api path /api*
  handle @api {
    reverse_proxy backend:3000
  }

  @socket path /socket.io*
  handle @socket {
    reverse_proxy backend:3000
  }

  @admin_redirect path /admin
  redir @admin_redirect /admin/ 301

  handle_path /admin/* {
    root * /srv/admin
    try_files {path} /index.html
    file_server
  }

  handle {
    root * /srv/frontend
    try_files {path} /index.html
    file_server
  }
}

io-rtchat.xyz {
  import app
}

localhost, 127.0.0.1 {
  tls internal
  import app
}
